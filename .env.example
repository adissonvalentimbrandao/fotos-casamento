# Copie para .env apenas em desenvolvimento local (opcional)
# Na Render, configure no painel: Environment → Environment Variables

# Porta (Render define automaticamente — não precisa alterar lá)
PORT=3000

# Ambiente
NODE_ENV=production

# URL pública do site — usada no QR Code e links de captura
# Só precisa definir se usar DOMÍNIO CUSTOMIZADO na Render.
# Exemplo: https://fotos.seudominio.com.br
# PUBLIC_URL=https://fotos.seudominio.com.br

# Render injeta automaticamente (NÃO defina manualmente no painel):
# RENDER_EXTERNAL_URL=https://fotos-casamento.onrender.com
# RENDER=true

# Pasta persistente para fotos + SQLite (ative o disco em /var/data na Render)
# DATA_DIR=/var/data
